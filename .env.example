# CAT Printer Web Interface - Environment Variables
# Copy this file to .env and customize values

# Printer Configuration
# MAC address of your CAT thermal printer
CAT_PRINTER_MAC=A1:49:35:A0:C8:79

# Working directory for print jobs and data
PRINTER_WORKDIR=/app/catprinter

# Keep-alive ping interval in seconds (default: 150 = 2.5 minutes)
PING_INTERVAL=150

# Flask Server Configuration
# Port to run the web server
FLASK_PORT=5000

# Secret key for session security (change to a random value)
SECRET_KEY=changeme-to-a-random-secret-key

# Security Configuration
# Enable authentication (recommended for internet access)
ENABLE_AUTH=true

# Admin username
ADMIN_USER=admin

# Admin password (CHANGE THIS!)
ADMIN_PASSWORD=changeme

# Data Files
# Path to store tasks JSON file
DATA_FILE=/app/data/tareas.json